{
  "schema": "frozenlands.module.index.v1",
  "module": "provider-model",
  "modulePath": "modulesSrc/provider-model",
  "id": "engine.model",
  "type": "provider",
  "entrypoint": "org.takesome.frozenlands.engine.providers.model.ModelProvider",
  "description": "Model provider module. Java loads and attaches models; Lua calls module commands through java.callModule.",
  "project": {
    "id": "takesome.frozenlands",
    "name": "Take Some() Frozen Lands",
    "projectModule": true,
    "moduleRole": "provider",
    "moduleLayer": "providers",
    "sourceRoot": "modulesSrc/provider-model"
  },
  "lua": {
    "api": "src/main/resources/scripts/lua/api.lua",
    "events": "src/main/resources/scripts/lua/events.lua",
    "usage": "local model = require('engine.model'); model.call('load', { path = 'Models/char.glb' })"
  },
  "runtime": {
    "configs": {
      "models": "src/main/resources/config/models.json"
    },
    "assetRoots": [
      "src/main/resources"
    ]
  }
}