{
  "schema": "frozenlands.module.index.v1",
  "module": "engine:modules:provider-model",
  "id": "engine.model",
  "type": "provider",
  "entrypoint": "org.takesome.frozenlands.engine.providers.model.ModelProvider",
  "description": "Model provider module. Java loads and attaches models; Lua calls module commands through java.callModule.",
  "lua": {
    "api": "lua/api.lua",
    "events": "lua/events.lua",
    "usage": "local model = require('engine.model'); model.call('load', { path = 'Models/char.glb' })"
  },
  "runtime": {
    "configs": {
      "models": "assets/config/models.json"
    },
    "assetRoots": [
      "assets"
    ]
  },
  "modulePath": "engine:modules:provider-model"
}
