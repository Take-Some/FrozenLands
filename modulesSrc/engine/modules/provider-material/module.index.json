{
  "schema": "frozenlands.module.index.v1",
  "module": "engine:modules:provider-material",
  "id": "engine.material",
  "type": "provider",
  "entrypoint": "org.takesome.frozenlands.engine.providers.material.MaterialProvider",
  "description": "Material provider module. Java executes material loading; Lua calls module commands through java.callModule.",
  "lua": {
    "api": "lua/api.lua",
    "events": "lua/events.lua",
    "usage": "local material = require('engine.material'); material.call('list', {})"
  },
  "runtime": {
    "configs": {
      "materials": "assets/config/materials.json"
    },
    "assetRoots": [
      "assets"
    ]
  },
  "modulePath": "engine:modules:provider-material"
}
