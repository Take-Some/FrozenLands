{
  "schema": "takesome.frozenlands.ui.bindings.v1",
  "actions": {
    "game.new": {
      "native": true,
      "description": "Start a new world/session and switch to HUD."
    },
    "game.continue": {
      "native": true,
      "description": "Continue the last save and switch to HUD."
    },
    "game.resume": {
      "native": true,
      "description": "Resume gameplay from menu UI."
    },
    "game.save": {
      "native": true,
      "module": "engine.save",
      "command": "save"
    },
    "game.load": {
      "native": true,
      "module": "engine.save",
      "command": "load"
    },
    "game.exitToDesktop": {
      "native": true,
      "description": "Request application shutdown."
    },
    "ui.settings": {
      "native": false,
      "description": "Open settings screen when implemented."
    },
    "ui.pause": {
      "native": false,
      "description": "Switch shell to pause screen."
    },
    "ui.mainMenu": {
      "native": false,
      "description": "Switch shell to main menu screen."
    },
    "ui.devtoolsHint": {
      "native": false,
      "description": "Informational button; DevTools opens with F12."
    },
    "tool.select.1": {
      "native": true,
      "description": "Select first quick tool."
    },
    "tool.select.2": {
      "native": true,
      "description": "Select second quick tool."
    },
    "tool.select.3": {
      "native": true,
      "description": "Select third quick tool."
    }
  },
  "state": {
    "hud-temperature": "weather.temperature",
    "hud-heat-fill": "player.bodyHeat.percent",
    "hud-stamina-fill": "player.stamina.percent",
    "hud-hunger-fill": "player.hunger.percent",
    "hud-pos-x": "player.position.x",
    "hud-pos-y": "player.position.y",
    "hud-pos-z": "player.position.z",
    "hud-compass-heading": "player.compass.heading",
    "hud-objective-title": "quest.current.title",
    "hud-objective-hint": "quest.current.hint"
  }
}
